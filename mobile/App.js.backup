  {
    id: "granola-001",
    code: "000001",
    barcode: "000001",
    name: "Crunchy Granola",
    brand: "GoodGrain",
    category: "Breakfast",
    nutriments: { energy: 420, fat: 12, saturatedFat: 2, carbs: 65, sugar: 18, protein: 9, fiber: 7, salt: 0.6 },
  },
  {
    id: "yogurt-002",
    code: "000002",
    barcode: "000002",
    name: "Greek Yogurt (Low Fat)",
    brand: "CreamCo",
    category: "Dairy",
    nutriments: { energy: 95, fat: 2, saturatedFat: 1, carbs: 6, sugar: 5, protein: 10, fiber: 0, salt: 0.2 },
  },
  {
    id: "choc-003",
    code: "000003",
    barcode: "000003",
    name: "Milk Chocolate Bar",
    brand: "ChocoBite",
    category: "Snacks",
    nutriments: { energy: 540, fat: 32, saturatedFat: 20, carbs: 55, sugar: 50, protein: 6, fiber: 2, salt: 0.3 },
  },
  {
    id: "chips-004",
    code: "000004",
    barcode: "000004",
    name: "Sea Salt Crisps",
    brand: "Crunchies",
    category: "Snacks",
    nutriments: { energy: 510, fat: 32, saturatedFat: 3, carbs: 50, sugar: 1, protein: 6, fiber: 4, salt: 1.3 },
  },
  {
    id: "apple-005",
    code: "000005",
